{
  "name": "@fusedio/widgets",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Fused JSON-UI render surface — the defineComponent widget catalog, the registry/renderer, the canvas, and the Python-artifact generator. Consumed as source (no npm publish).",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*",
    "./widget.css": "./src/widget.css"
  },
  "scripts": {
    "generate": "tsx scripts/generate.ts",
    "typecheck": "tsc --noEmit",
    "check:widget-imports": "node scripts/check-widget-imports.mjs",
    "test": "vitest run",
    "test:browser": "vitest run --config vitest.browser.config.ts"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@deck.gl/aggregation-layers": "^9.1.0",
    "@deck.gl/core": "^9.1.0",
    "@deck.gl/geo-layers": "^9.1.0",
    "@deck.gl/layers": "^9.1.0",
    "@deck.gl/mapbox": "^9.1.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fusedio/ui-kit": "workspace:*",
    "@fusedio/widget-sdk": "0.3.1",
    "@xyflow/react": "^12.11.0",
    "h3-js": "^4.1.0",
    "lucide-react": "^0.574.0",
    "maplibre-gl": "^4.7.1",
    "react-markdown": "^9.0.1",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.3.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.19.42",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/browser": "^4.1.8",
    "@vitest/browser-playwright": "^4.1.8",
    "playwright": "1.56.0",
    "tsx": "^4.22.4",
    "typescript": "^5.4.5",
    "vitest": "^4.1.8",
    "zod": "^4.3.6"
  }
}
