{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["node"],
    "lib": ["ES2022"]
  },
  // Tests are type-checked too (not excluded) so the editor services src/**/*.test.ts
  // via this project instead of an inferred default; they import from "vitest"
  // explicitly, so no extra global types are needed.
  "include": ["src/**/*.ts"]
}
