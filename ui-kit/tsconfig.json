{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  },
  // Tests are type-checked too (not excluded) so the editor services
  // src/**/*.test.tsx via this project instead of an inferred default. The
  // jest-dom matcher augmentation (src/vitest-jest-dom.d.ts) is picked up by the
  // src/**/*.ts glob so `toHaveAttribute` etc. type-check.
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
